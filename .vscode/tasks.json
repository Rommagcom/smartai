		{
			"label": "smoke-all-via-just",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"cd backend && just smoke-all"
			],
			"isBackground": false
		},
		{
			"label": "multi-up-via-just",
			"type": "shell",
			"command": "cmd",
