				"/c",
				"cd backend && just multi-up"
			],
			"isBackground": false
		},
		{
			"label": "multi-up-direct",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"cd backend && docker compose -f docker-compose.yml -f docker-compose.multi.yml --profile multi up -d --build --scale worker=3"
			],
			"isBackground": false
		},
